    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "// Keyword + heuristic classifier (no AI key needed). Topic + urgency + sentiment.\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  const text = ((j.subject || '') + ' ' + (j.message || '')).toLowerCase();\n  const has = function (words) { return words.some(function (w) { return text.indexOf(w) !== -1; }); };\n\n  let topic = 'general';\n  if (has(['refund','charge','invoice','billing','payment','card'])) topic = 'billing';\n  else if (has(['bug','error','broken','crash','not working','500','fail'])) topic = 'bug';\n  else if (has(['password','login','access','locked','2fa','reset'])) topic = 'account';\n  else if (has(['cancel','downgrade','churn','close account'])) topic = 'retention';\n  else if (has(['feature','request','suggest','would be nice'])) topic = 'feature';\n\n  let urgency = 'normal';\n  if (has(['urgent','asap','immediately','down','outage','can\\'t access','critical','emergency'])) urgency = 'high';\n  else if (has(['whenever','no rush','minor','question'])) urgency = 'low';\n\n  const negWords = ['angry','terrible','worst','unacceptable','furious','disappointed','scam','refund'];\n  const negHits = negWords.filter(function (w) { return text.indexOf(w) !== -1; }).length;\n  const sentiment = negHits >= 2 ? 'negative' : (negHits === 1 ? 'mixed' : 'neutral');\n\n  out.push({ json: Object.assign({}, j, { topic: topic, urgency: urgency, sentiment: sentiment, classifiedAt: $now.toISO() }) });\n}\nreturn out;"
      },
      "id": "44444444-0006-4001-8001-000000000006",
      "name": "Classify (topic/urgency/sentiment)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [260, -40]
    },
