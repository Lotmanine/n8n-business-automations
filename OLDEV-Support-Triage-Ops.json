        "language": "javaScript",
        "jsCode": "// Flag tickets whose SLA due time has passed.\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  const due = j.dueAt ? new Date(j.dueAt).getTime() : null;\n  const breached = due !== null && due < $now.toMillis();\n  const overdueMin = (due !== null && breached) ? Math.round(($now.toMillis() - due) / 60000) : 0;\n  out.push({ json: Object.assign({}, j, { breached: breached, overdueMin: overdueMin }) });\n}\nreturn out;"
