    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const base = $('Classify (topic/urgency/sentiment)').first().json;\nconst mx = $('Enrich: MX Lookup').first().json || {};\nconst rdap = $('Enrich: RDAP Domain').first().json || {};\nconst disp = $('Enrich: Disposable Check').first().json || {};\n\nconst hasMx = !!(mx && mx.Answer && mx.Answer.length);\nlet ageDays = null;\nif (rdap && Array.isArray(rdap.events)) {\n  const reg = rdap.events.find(function (e) { return e.eventAction === 'registration'; });\n  if (reg && reg.eventDate) ageDays = Math.round(($now.toMillis() - new Date(reg.eventDate).getTime()) / 86400000);\n}\nconst isDisposable = !!(disp && disp.disposable === true);\nconst businessDomain = hasMx && !isDisposable;\n\nreturn [{ json: Object.assign({}, base, {\n  hasMx: hasMx, domainAgeDays: ageDays, isDisposable: isDisposable, businessDomain: businessDomain\n}) }];"
      },
      "id": "44444444-0011-4001-8001-000000000011",
      "name": "Fold Enrichment",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [960, 0]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "// Priority score from plan + urgency + sentiment + whether it's a real business domain.\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  let score = 0;\n  const planWeight = { enterprise: 40, pro: 25, paid: 20, free: 5 };\n  score += (planWeight[j.plan] != null ? planWeight[j.plan] : 5);\n  if (j.urgency === 'high') score += 35; else if (j.urgency === 'low') score -= 10;\n  if (j.sentiment === 'negative') score += 20; else if (j.sentiment === 'mixed') score += 8;\n  if (j.topic === 'retention') score += 25;\n  if (j.topic === 'billing') score += 10;\n  if (j.businessDomain) score += 10; else score -= 5;\n  if (j.isDisposable) score -= 25;\n  if (score < 0) score = 0; if (score > 100) score = 100;\n\n  // SLA minutes by tier\n  let priority = 'P3';\n  if (score >= 70) priority = 'P1'; else if (score >= 45) priority = 'P2';\n  const slaMinutes = priority === 'P1' ? 30 : (priority === 'P2' ? 240 : 1440);\n  const dueAt = $now.plus({ minutes: slaMinutes }).toISO();\n\n  out.push({ json: Object.assign({}, j, { priorityScore: score, priority: priority, slaMinutes: slaMinutes, dueAt: dueAt }) });\n}\nreturn out;"
      },
